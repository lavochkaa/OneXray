.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Xcode user state (breakpoints, window positions, user-scoped schemes)
**/xcuserdata/
*.xcuserstate

# Environment variables / local secrets
.env
.env.*
!.env.example

# Signing material (broad patterns — catches stray drops)
*.p8
*.p12
*.cer
*.pem
*.jks
*.keystore
*.mobileprovision
*.provisionprofile
**/AuthKey_*

# Android signing passwords
android/key.properties
android/app/key.properties

# Firebase / Google Services (any path)
**/GoogleService-Info.plist
**/google-services.json
firebase.json
lib/firebase_options.dart

# Fastlane artifacts (but Fastfiles themselves stay public)
**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/test_output/
**/fastlane/screenshots/
**/fastlane/metadata/

